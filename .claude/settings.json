{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": ["Read(**/.env.local)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "mise exec -- bun .claude/hooks/redirect-to-opensrc.ts",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "mise exec -- bun .claude/hooks/format-file.ts",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "mise exec -- bun .claude/hooks/lint-file.ts",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
