{
  "name": "@gunta/confect-server",
  "version": "7.0.0",
  "description": "Backend bindings to the Convex platform",
  "repository": {
    "type": "git",
    "url": "https://github.com/rjdellecese/confect.git"
  },
  "bugs": {
    "url": "https://github.com/rjdellecese/confect/issues"
  },
  "homepage": "https://confect.dev",
  "sideEffects": false,
  "type": "module",
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "dist",
    "package.json",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    },
    "./package.json": "./package.json",
    "./internal/*": null,
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "fix": "prettier --write . && eslint --fix . --max-warnings=0",
    "format": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "bench": "tsx test/SchemaToValidator.bench.ts",
    "clean": "rm -rf dist coverage node_modules",
    "prepack": "rm -f ./README.md && cp ../../README.md ./README.md",
    "postpack": "rm ./README.md && ln -s ../../README.md ./README.md"
  },
  "keywords": [
    "effect",
    "convex"
  ],
  "author": "RJ Dellecese",
  "license": "ISC",
  "devDependencies": {
    "@ark/attest": "0.56.0",
    "@gunta/confect-cli": "workspace:*",
    "@gunta/confect-test": "workspace:*",
    "@eslint/js": "10.0.1",
    "@swc/jest": "0.2.39",
    "@types/node": "25.3.3",
    "@vitest/coverage-v8": "3.2.4",
    "convex-test": "^0.0.53",
    "dotenv": "17.3.1",
    "effect": "4.0.0-beta.67",
    "eslint": "10.0.2",
    "prettier": "3.8.1",
    "tsdown": "0.20.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "3.2.4"
  },
  "peerDependencies": {
    "@gunta/confect-core": "workspace:*",
    "convex": "^1.39.0",
    "effect": "4.0.0-beta.67"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
