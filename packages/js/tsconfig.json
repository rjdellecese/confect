{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "isolatedDeclarations": false,
    "noEmit": true,
    "skipLibCheck": true,
    "exactOptionalPropertyTypes": true,
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "paths": {
      "@confect/js": ["./src/index.ts"],
      "@confect/js/*": ["./src/*"]
    }
  },
  "exclude": ["coverage", "dist", "node_modules"],
  "extends": ["../../tsconfig.base.json"]
}
