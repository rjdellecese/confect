{
  "devDependencies": {
    "@changesets/cli": "2.29.8",
    "@changesets/config": "3.1.2",
    "@effect/language-service": "0.86.1",
    "@effect/platform": "0.96.1",
    "@effect/platform-bun": "0.89.0",
    "@eslint/js": "10.0.1",
    "@types/node": "25.3.3",
    "@vitest/coverage-v8": "3.2.4",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "effect": "3.21.2",
    "eslint": "10.0.2",
    "eslint-plugin-mdx": "3.7.0",
    "eslint-plugin-unicorn": "64.0.0",
    "opensrc": "0.7.2",
    "prettier": "3.8.1",
    "syncpack": "15.3.1",
    "tsdown": "0.20.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "3.2.4"
  },
  "keywords": [
    "convex",
    "effect"
  ],
  "license": "ISC",
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "build": "pnpm -r --filter='@confect/*' build",
    "build:core": "pnpm --filter @confect/core build",
    "build:js": "pnpm --filter @confect/js build",
    "build:react": "pnpm --filter @confect/react build",
    "build:server": "pnpm --filter @confect/server build",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "codegen:server:local-backend": "pnpm --filter @confect/server codegen:local-backend",
    "codegen:server:mock-backend": "pnpm --filter @confect/server codegen:mock-backend",
    "dev": "pnpm -r --parallel dev",
    "dev:apps": "pnpm --filter='docs example' dev",
    "dev:apps:docs": "pnpm --filter docs dev",
    "dev:apps:example": "pnpm --filter example dev",
    "dev:packages": "pnpm --filter='@confect/*' dev",
    "dev:packages:cli": "pnpm --filter @confect/cli dev",
    "dev:packages:core": "pnpm --filter @confect/core dev",
    "dev:packages:js": "pnpm --filter @confect/js dev",
    "dev:packages:react": "pnpm --filter @confect/react dev",
    "dev:packages:server": "pnpm --filter @confect/server dev",
    "dev:packages:test": "pnpm --filter @confect/test dev",
    "fix": "pnpm -r fix && pnpm fix:syncpack",
    "fix:syncpack": "syncpack format",
    "format": "pnpm -r format && pnpm format:syncpack",
    "format:syncpack": "syncpack format --check",
    "lint": "pnpm -r lint && pnpm lint:syncpack && pnpm lint:metadata && pnpm lint:claude-settings",
    "lint:claude-settings": "node scripts/check-claude-settings.mjs",
    "lint:core": "pnpm --filter @confect/core lint",
    "lint:docs": "pnpm --filter docs lint",
    "lint:example": "pnpm --filter example lint",
    "lint:js": "pnpm --filter @confect/js lint",
    "lint:metadata": "node scripts/check-package-metadata.mjs",
    "lint:react": "pnpm --filter @confect/react lint",
    "lint:server": "pnpm --filter @confect/server lint",
    "lint:syncpack": "syncpack lint",
    "prepare": "effect-language-service patch",
    "release": "pnpm build && changeset publish",
    "test:cli": "vitest run --project @confect/cli",
    "test:core": "vitest run --project @confect/core",
    "test:js": "vitest run --project @confect/js",
    "test:react": "vitest run --project @confect/react",
    "test:server": "vitest run --project @confect/server",
    "test:server:local-backend": "pnpm --filter @confect/server test:local-backend",
    "test:server:mock-backend": "pnpm --filter @confect/server test:mock-backend",
    "typecheck": "pnpm -r typecheck",
    "typecheck:core": "pnpm --filter @confect/core typecheck",
    "typecheck:example": "pnpm --filter example typecheck",
    "typecheck:js": "pnpm --filter @confect/js typecheck",
    "typecheck:react": "pnpm --filter @confect/react typecheck",
    "typecheck:server": "pnpm --filter @confect/server typecheck",
    "typecheck:test": "pnpm --filter @confect/test typecheck"
  }
}
