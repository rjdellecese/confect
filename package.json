{
  "name": "@gunta/confect-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm -r --filter='@gunta/confect-*' build",
    "build:core": "pnpm --filter @gunta/confect-core build",
    "build:server": "pnpm --filter @gunta/confect-server build",
    "build:js": "pnpm --filter @gunta/confect-js build",
    "build:react": "pnpm --filter @gunta/confect-react build",
    "dev": "pnpm -r --parallel dev",
    "dev:packages": "pnpm --filter='@gunta/confect-*' dev",
    "dev:packages:cli": "pnpm --filter @gunta/confect-cli dev",
    "dev:packages:core": "pnpm --filter @gunta/confect-core dev",
    "dev:packages:js": "pnpm --filter @gunta/confect-js dev",
    "dev:packages:server": "pnpm --filter @gunta/confect-server dev",
    "dev:packages:react": "pnpm --filter @gunta/confect-react dev",
    "dev:packages:test": "pnpm --filter @gunta/confect-test dev",
    "dev:apps": "pnpm --filter='docs example' dev",
    "dev:apps:docs": "pnpm --filter docs dev",
    "dev:apps:example": "pnpm --filter example dev",
    "typecheck": "pnpm -r typecheck",
    "typecheck:core": "pnpm --filter @gunta/confect-core typecheck",
    "typecheck:server": "pnpm --filter @gunta/confect-server typecheck",
    "typecheck:js": "pnpm --filter @gunta/confect-js typecheck",
    "typecheck:react": "pnpm --filter @gunta/confect-react typecheck",
    "typecheck:test": "pnpm --filter @gunta/confect-test typecheck",
    "typecheck:example": "pnpm --filter example typecheck",
    "lint": "pnpm -r lint",
    "lint:core": "pnpm --filter @gunta/confect-core lint",
    "lint:server": "pnpm --filter @gunta/confect-server lint",
    "lint:js": "pnpm --filter @gunta/confect-js lint",
    "lint:react": "pnpm --filter @gunta/confect-react lint",
    "lint:docs": "pnpm --filter docs lint",
    "lint:example": "pnpm --filter example lint",
    "fix": "pnpm -r fix",
    "format": "pnpm -r format",
    "test:core": "vitest run --project @gunta/confect-core",
    "test:js": "vitest run --project @gunta/confect-js",
    "test:react": "vitest run --project @gunta/confect-react",
    "test:server": "vitest run --project @gunta/confect-server",
    "test:cli": "vitest run --project @gunta/confect-cli",
    "release": "pnpm build && changeset publish",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "prepare": "effect-language-service patch"
  },
  "keywords": [
    "effect",
    "convex"
  ],
  "license": "ISC",
  "devDependencies": {
    "@changesets/cli": "2.29.8",
    "@changesets/config": "3.1.2",
    "@effect/language-service": "0.86.1",
    "@eslint/js": "10.0.1",
    "@types/node": "25.3.3",
    "@vitest/coverage-v8": "3.2.4",
    "bun": "1.3.10",
    "effect": "4.0.0-beta.67",
    "eslint": "10.0.2",
    "eslint-plugin-mdx": "3.7.0",
    "opensrc": "0.7.2",
    "prettier": "3.8.1",
    "tsdown": "0.20.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=22.13",
    "pnpm": "11.0.9"
  },
  "packageManager": "pnpm@11.0.9"
}
