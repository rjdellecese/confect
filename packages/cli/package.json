{
  "name": "@confect/cli",
  "description": "Developer tooling for codegen and sync",
  "version": "9.0.0-next.9",
  "author": "RJ Dellecese",
  "bin": {
    "confect": "./dist/index.mjs"
  },
  "bugs": {
    "url": "https://github.com/rjdellecese/confect/issues"
  },
  "dependencies": {
    "@effect/cli": "^0.75.1",
    "@effect/platform": "0.96.1",
    "@effect/platform-node": "0.106.0",
    "@effect/platform-node-shared": "0.59.0",
    "@effect/printer": "^0.49.0",
    "@effect/printer-ansi": "^0.49.0",
    "bundle-require": "^5.1.0",
    "code-block-writer": "^13.0.3",
    "esbuild": "^0.27.3"
  },
  "devDependencies": {
    "@effect/language-service": "0.86.1",
    "@effect/vitest": "0.29.0",
    "@types/node": "25.3.3",
    "@vitest/coverage-v8": "3.2.4",
    "effect": "3.21.2",
    "tsdown": "0.20.3",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "dist",
    "package.json",
    "src"
  ],
  "homepage": "https://confect.dev",
  "keywords": [
    "cli",
    "convex",
    "effect"
  ],
  "license": "ISC",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "peerDependencies": {
    "@confect/core": "workspace:^",
    "@confect/server": "workspace:^",
    "effect": "^3.21.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rjdellecese/confect.git"
  },
  "scripts": {
    "clean": "rm -rf dist coverage node_modules",
    "dev": "tsdown --watch --config-loader unrun",
    "postpack": "rm ./README.md && ln -s ../../README.md ./README.md",
    "prepack": "rm -f ./README.md && cp ../../README.md ./README.md",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.ts"
}
