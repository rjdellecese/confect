{
  "name": "@confect/js",
  "description": "JavaScript client bindings for any JS runtime",
  "version": "9.2.4",
  "author": "RJ Dellecese",
  "bugs": {
    "url": "https://github.com/rjdellecese/confect/issues"
  },
  "devDependencies": {
    "@effect/vitest": "0.30.0",
    "@types/node": "26.1.1",
    "effect": "3.22.0",
    "tsdown": "0.22.12",
    "typescript": "6.0.3",
    "unrun": "0.3.1",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "dist",
    "package.json",
    "src"
  ],
  "homepage": "https://confect.dev",
  "keywords": [
    "convex",
    "effect"
  ],
  "license": "ISC",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "peerDependencies": {
    "@confect/core": "workspace:^",
    "convex": "^1.32.0",
    "effect": "^3.21.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rjdellecese/confect.git"
  },
  "scripts": {
    "clean": "rm -rf dist coverage node_modules",
    "dev": "tsdown --watch --config-loader unrun",
    "postpack": "rm ./README.md && ln -s ../../README.md ./README.md",
    "prepack": "rm -f ./README.md && cp ../../README.md ./README.md",
    "test": "vitest run",
    "typecheck": "tsc -b tsconfig.src.json"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.ts"
}
