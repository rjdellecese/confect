{
  "name": "@confect/cli",
  "description": "Developer tooling for codegen and sync",
  "version": "10.0.0-next.2",
  "author": "RJ Dellecese",
  "bin": {
    "confect": "./bin/confect.mjs"
  },
  "bugs": {
    "url": "https://github.com/rjdellecese/confect/issues"
  },
  "dependencies": {
    "@effect/platform-node": "^4.0.0-beta.100",
    "bundle-require": "^5.1.0",
    "code-block-writer": "^13.0.3",
    "esbuild": "0.27.0 - 0.27.3 || ^0.27.5 || ^0.28.0",
    "exsolve": "^1.1.0"
  },
  "devDependencies": {
    "@convex-dev/workpool": "0.4.8",
    "@effect/language-service": "0.87.0",
    "@effect/vitest": "4.0.0-beta.100",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "convex": "1.40.0",
    "effect": "4.0.0-beta.100",
    "tsdown": "0.22.12",
    "typescript": "6.0.3",
    "unrun": "0.3.1",
    "vite": "8.1.5",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    "./package.json": "./package.json"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "bin",
    "dist",
    "package.json"
  ],
  "homepage": "https://confect.dev",
  "keywords": [
    "cli",
    "convex",
    "effect"
  ],
  "license": "ISC",
  "peerDependencies": {
    "@confect/core": "workspace:^",
    "@confect/server": "workspace:^",
    "effect": "^4.0.0-beta.100"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rjdellecese/confect.git"
  },
  "scripts": {
    "clean": "rm -rf dist coverage node_modules",
    "dev": "tsdown --watch --config-loader unrun",
    "postpack": "rm ./README.md && ln -s ../../README.md ./README.md",
    "prepack": "rm -f ./README.md && cp ../../README.md ./README.md",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "type": "module"
}
