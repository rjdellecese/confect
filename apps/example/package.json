{
  "name": "example",
  "version": "0.0.0",
  "dependencies": {
    "@confect/cli": "workspace:*",
    "@confect/core": "workspace:*",
    "@confect/react": "workspace:*",
    "@confect/server": "workspace:*",
    "@convex-dev/workpool": "0.4.7",
    "convex": "1.40.0",
    "convex-helpers": "0.1.120",
    "effect": "4.0.0-beta.99",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "vite": "8.1.4"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "typescript": "6.0.3",
    "vite-plus": "0.2.4"
  },
  "private": true,
  "scripts": {
    "build": "vite build --mode development",
    "clean": "rm -rf dist node_modules",
    "convex-codegen": "pnpm convex codegen",
    "dev": "concurrently --restart-tries=1 --prefix-colors='white.bold.bgCyan,white.bold.bgYellow,white.bold.bgGreen' --prefix=' {name} ' --names='VITE,CONVEX,CONFECT' 'vite' 'convex dev --tail-logs' 'confect dev'",
    "typecheck": "tsc --noEmit --project tsconfig.json && tsc --noEmit --project convex/tsconfig.json"
  },
  "type": "module"
}
