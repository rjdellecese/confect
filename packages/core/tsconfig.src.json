{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "rootDir": "src",
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "tsBuildInfoFile": "dist/tsconfig.src.tsbuildinfo",
    "isolatedDeclarations": false,
    "skipLibCheck": true,
    "exactOptionalPropertyTypes": true,
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "moduleResolution": "Bundler",
    "module": "ESNext"
  },
  "include": ["src"]
}
