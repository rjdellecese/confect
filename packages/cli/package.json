{
  "name": "@confect/cli",
  "description": "Developer tooling for codegen and sync",
  "version": "10.0.0-next.0",
  "author": "RJ Dellecese",
  "bin": {
    "confect": "./dist/index.mjs"
  },
  "bugs": {
    "url": "https://github.com/rjdellecese/confect/issues"
  },
  "dependencies": {
    "@effect/platform-node": "^4.0.0-beta.97",
    "bundle-require": "^5.1.0",
    "code-block-writer": "^13.0.3",
    "esbuild": "^0.27.3",
    "exsolve": "^1.1.0"
  },
  "devDependencies": {
    "@convex-dev/workpool": "0.4.6",
    "@effect/language-service": "0.86.2",
    "@effect/vitest": "4.0.0-beta.97",
    "@types/node": "25.3.3",
    "@vitest/coverage-v8": "3.2.4",
    "convex": "1.40.0",
    "effect": "4.0.0-beta.97",
    "tsdown": "0.20.3",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    "./package.json": "./package.json"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "dist",
    "package.json"
  ],
  "homepage": "https://confect.dev",
  "keywords": [
    "cli",
    "convex",
    "effect"
  ],
  "license": "ISC",
  "peerDependencies": {
    "@confect/core": "workspace:^",
    "@confect/server": "workspace:^",
    "effect": "^4.0.0-beta.97"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rjdellecese/confect.git"
  },
  "scripts": {
    "clean": "rm -rf dist coverage node_modules",
    "dev": "tsdown --watch --config-loader unrun",
    "postpack": "rm ./README.md && ln -s ../../README.md ./README.md",
    "prepack": "rm -f ./README.md && cp ../../README.md ./README.md",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "type": "module"
}
